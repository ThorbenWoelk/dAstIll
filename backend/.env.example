AWS_REGION=eu-central-1
S3_DATA_BUCKET=dastill-data-eu-central-1
S3_VECTOR_BUCKET=dastill-vectors
S3_VECTOR_INDEX=search-chunks
BACKEND_PROXY_TOKEN=local-dev-backend-proxy-token
BACKEND_CORS_ALLOWED_ORIGINS=http://localhost:3543
# Optional: per-client HTTP limits (rolling 60s window). Defaults: 600 baseline, 120 expensive.
# BASELINE_RATE_LIMIT_PER_MINUTE=600
# EXPENSIVE_RATE_LIMIT_PER_MINUTE=120
# Production only (set by Terraform on Cloud Run):
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/dastill-gcp-backend
# AWS_WIF_AUDIENCE=<backend-sa-unique-id>
YOUTUBE_API_KEY=your-youtube-api-key
OLLAMA_URL=http://localhost:11434
# For Ollama cloud API: OLLAMA_URL=https://ollama.com and set OLLAMA_API_KEY
OLLAMA_API_KEY=your-ollama-api-key
# Optional: Logfire observability for backend tracing / AI pipeline events.
# Leave unset to log locally via tracing_subscriber only.
# LOGFIRE_TOKEN=your-logfire-token
OLLAMA_MODEL=glm-5:cloud
OLLAMA_FALLBACK_MODEL=gemma3:27b
OLLAMA_CHAT_MODEL=glm-5:cloud
SUMMARY_EVALUATOR_MODEL=qwen3.5:397b-cloud
SEARCH_SEMANTIC_ENABLED=true
OLLAMA_EMBEDDING_MODEL=embeddinggemma:latest
SEARCH_AUTO_CREATE_VECTOR_INDEX=false
SUMMARIZE_PATH=/opt/homebrew/bin/summarize
DATABRICKS_HOST=https://dbc-xxxxxxxx.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-pat
DATABRICKS_WAREHOUSE_ID=your-warehouse-id
# Optional overrides for the analytics landing table:
# DATABRICKS_CATALOG=workspace
# DATABRICKS_SCHEMA=sandbox
# DATABRICKS_BRONZE_TABLE=bronze_app_events
# Optional Amazon Polly TTS for summary audio playback:
# POLLY_TTS_ENABLED=true
# POLLY_TTS_VOICE_ID=Joanna
# POLLY_TTS_ENGINE=neural
# POLLY_TTS_OUTPUT_FORMAT=mp3
