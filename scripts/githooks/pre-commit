#!/bin/bash
# Pre-commit hook for dAstIll project
# Runs ruff linting and basic tests before allowing commit

echo "🔍 Running pre-commit checks..."

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "❌ Not in a git repository"
    exit 1
fi

# Check if uv is available
if ! command -v uv &> /dev/null; then
    echo "❌ uv not found. Please install uv first."
    exit 1
fi

# Get list of staged Python files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(py)$')

if [[ -n "$STAGED_FILES" ]]; then
    echo "📋 Staged Python files:"
    echo "$STAGED_FILES"
    echo ""

    # Run ruff check on staged files
    echo "🔧 Running ruff check..."
    if ! uv run ruff check $STAGED_FILES; then
        echo "❌ Ruff check failed. Please fix the issues above."
        exit 1
    fi

    # Run ruff format check on staged files
    echo "🎨 Checking code formatting..."
    if ! uv run ruff format --check $STAGED_FILES; then
        echo "❌ Code formatting issues found. Run 'uv run ruff format .' to fix them."
        exit 1
    fi

    # Run tests if any test files are staged or if source files changed
    if echo "$STAGED_FILES" | grep -E '(test_|src/)' > /dev/null; then
        echo "🧪 Running tests..."
        if ! uv run pytest tests/ -x --tb=short; then
            echo "❌ Tests failed. Please fix failing tests before committing."
            exit 1
        fi
    fi
else
    echo "✅ No Python files staged, skipping Python checks"
fi

# Frontend Audit
FRONTEND_STAGED=$(git diff --cached --name-only | grep -E '^frontend/(package\.json|bun\.lock|bun\.lockb)$')
if [[ -n "$FRONTEND_STAGED" ]]; then
    echo "🔒 Running frontend bun audit..."
    if ! (cd frontend && bun audit --production); then
        echo "❌ Frontend audit failed. Please fix vulnerabilities before committing."
        exit 1
    fi
fi

# Backend Audit
BACKEND_STAGED=$(git diff --cached --name-only | grep -E '^backend/Cargo\.(toml|lock)$')
if [[ -n "$BACKEND_STAGED" ]]; then
    echo "🔒 Running backend cargo audit..."
    # 'cargo audit' is usually installed via 'cargo install cargo-audit'
    # We do not strictly check for its presence but will attempt to run it.
    if ! (cd backend && cargo audit); then
        echo "❌ Backend audit failed. Please fix vulnerabilities before committing."
        exit 1
    fi
fi

echo "✅ All pre-commit checks passed!"
exit 0
