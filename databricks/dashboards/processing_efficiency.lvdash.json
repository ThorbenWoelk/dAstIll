        {
          "widget": {
            "name": "table_slowest_videos",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "slowest_videos",
                  "fields": [
                    { "name": "video_id", "expression": "`video_id`" },
                    { "name": "channel_id", "expression": "`channel_id`" },
                    { "name": "duration_ms", "expression": "`duration_ms`" },
                    { "name": "p95_duration_ms", "expression": "`p95_duration_ms`" },
