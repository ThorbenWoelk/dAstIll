                  { "fieldName": "video_id",       "title": "Video ID",         "type": "string" },
                  { "fieldName": "channel_id",     "title": "Channel",          "type": "string" },
                  { "fieldName": "duration_ms",    "title": "Duration (ms)",    "type": "integer" },
                  { "fieldName": "p95_duration_ms","title": "P95 Duration (ms)","type": "integer" },
                  { "fieldName": "requested_at",   "title": "Requested At",     "type": "string" }
                ]
              },
              "frame": { "showTitle": true, "title": "Slowest Successful Videos (Top 20)" }
            }
          },
          "position": { "x": 0, "y": 14, "width": 6, "height": 8 }
        }
      ]
    }
  ],
  "datasets": [
    {
      "name": "processing_kpis",
      "displayName": "Processing KPIs",
      "query": "SELECT\n  COUNT(*) AS total_requests,\n  ROUND(SUM(CASE WHEN success THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS success_rate_pct,\n  ROUND(AVG(CASE WHEN success AND processing_duration_ms IS NOT NULL THEN processing_duration_ms END)) AS avg_success_duration_ms\nFROM analytics.gold_processing_efficiency"
    },
    {
      "name": "processing_by_channel",
      "displayName": "Processing by Channel",
      "query": "SELECT\n  channel_id,\n  COUNT(*) AS total_requests,\n  ROUND(SUM(CASE WHEN success THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS success_rate_pct,\n  ROUND(AVG(CASE WHEN success AND processing_duration_ms IS NOT NULL THEN processing_duration_ms END)) AS avg_duration_ms,\n  ROUND(PERCENTILE_APPROX(CASE WHEN success AND processing_duration_ms IS NOT NULL THEN processing_duration_ms END, 0.95)) AS p95_duration_ms\nFROM analytics.gold_processing_efficiency\nGROUP BY channel_id\nORDER BY avg_duration_ms DESC NULLS LAST"
    },
    {
      "name": "processing_trend",
      "displayName": "Daily Processing Trend",
      "query": "SELECT\n  event_date,\n  COUNT(*) AS request_count,\n  SUM(CASE WHEN success THEN 1 ELSE 0 END) AS success_count,\n  SUM(CASE WHEN NOT success THEN 1 ELSE 0 END) AS failure_count\nFROM analytics.gold_processing_efficiency\nGROUP BY event_date\nORDER BY event_date"
    },
    {
      "name": "slowest_videos",
      "displayName": "Slowest Videos",
      "query": "SELECT\n  video_id,\n  channel_id,\n  ROUND(processing_duration_ms) AS duration_ms,\n  ROUND(processing_duration_ms) AS p95_duration_ms,\n  DATE_FORMAT(requested_at, 'yyyy-MM-dd HH:mm') AS requested_at\nFROM analytics.gold_processing_efficiency\nWHERE success = TRUE\n  AND processing_duration_ms IS NOT NULL\nORDER BY processing_duration_ms DESC NULLS LAST\nLIMIT 20"
    }
  ]
}
