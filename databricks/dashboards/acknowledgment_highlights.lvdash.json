                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "channel_id",
                  "scale": { "type": "categorical" },
                  "displayName": "Channel"
                },
                "y": {
                  "fieldName": "total_highlights",
                  "scale": { "type": "quantitative" },
                  "displayName": "Total Highlights"
