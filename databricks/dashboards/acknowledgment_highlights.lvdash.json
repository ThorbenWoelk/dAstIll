              "frame": { "showTitle": true, "title": "Daily Acknowledgments" }
            }
          },
          "position": { "x": 0, "y": 9, "width": 6, "height": 5 }
        },
        {
          "widget": {
            "name": "table_top_highlighted",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "top_highlighted_videos",
                  "fields": [
                    { "name": "video_id", "expression": "`video_id`" },
                    { "name": "channel_id", "expression": "`channel_id`" },
                    { "name": "highlight_count", "expression": "`highlight_count`" },
                    { "name": "engagement_tier", "expression": "`engagement_tier`" },
                    { "name": "acknowledged", "expression": "`acknowledged`" }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {
                    "fieldName": "video_id",
                    "title": "Video ID",
                    "displayName": "Video ID",
                    "displayAs": "string",
                    "type": "string"
                  },
                  {
                    "fieldName": "channel_id",
                    "title": "Channel",
                    "displayName": "Channel",
                    "displayAs": "string",
                    "type": "string"
                  },
                  {
                    "fieldName": "highlight_count",
                    "title": "Highlights",
                    "displayName": "Highlights",
                    "displayAs": "number",
                    "type": "integer"
                  },
                  {
                    "fieldName": "engagement_tier",
                    "title": "Tier",
                    "displayName": "Tier",
                    "displayAs": "string",
                    "type": "string"
                  },
                  {
                    "fieldName": "acknowledged",
                    "title": "Acknowledged",
                    "displayName": "Acknowledged",
                    "displayAs": "string",
                    "type": "string"
                  }
                ]
              },
              "frame": { "showTitle": true, "title": "Most Highlighted Videos (Top 20)" }
            }
          },
          "position": { "x": 0, "y": 14, "width": 6, "height": 8 }
        }
      ]
    }
  ],
  "datasets": [
    {
      "name": "engagement_kpis",
      "displayName": "Engagement KPIs",
      "query": "SELECT\n  COUNT(*) AS total_videos,\n  SUM(CASE WHEN is_acknowledged THEN 1 ELSE 0 END) AS acknowledged_count,\n  SUM(highlight_count) AS total_highlights,\n  ROUND(SUM(CASE WHEN is_acknowledged THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS ack_rate_pct\nFROM analytics_dev.gold_engagement_progression"
    },
    {
      "name": "engagement_tier_distribution",
      "displayName": "Engagement Tier Distribution",
      "query": "SELECT\n  engagement_tier,\n  COUNT(*) AS video_count\nFROM analytics_dev.gold_engagement_progression\nGROUP BY engagement_tier\nORDER BY video_count DESC"
    },
    {
      "name": "highlights_by_channel",
      "displayName": "Highlights by Channel",
      "query": "SELECT\n  channel_id,\n  SUM(highlight_count) AS total_highlights,\n  COUNT(DISTINCT video_id) AS videos_with_highlights,\n  ROUND(SUM(highlight_count) * 1.0 / COUNT(DISTINCT video_id), 2) AS highlights_per_video\nFROM analytics_dev.gold_engagement_progression\nWHERE highlight_count > 0\nGROUP BY channel_id\nORDER BY total_highlights DESC"
    },
    {
      "name": "ack_trend",
      "displayName": "Daily Acknowledgment Trend",
      "query": "SELECT\n  DATE(first_acknowledged_at) AS event_date,\n  COUNT(*) AS acknowledgment_count\nFROM analytics_dev.gold_engagement_progression\nWHERE is_acknowledged = TRUE\n  AND first_acknowledged_at IS NOT NULL\nGROUP BY DATE(first_acknowledged_at)\nORDER BY event_date"
    },
    {
      "name": "top_highlighted_videos",
      "displayName": "Top Highlighted Videos",
      "query": "SELECT\n  video_id,\n  channel_id,\n  highlight_count,\n  engagement_tier,\n  CASE WHEN is_acknowledged THEN 'Yes' ELSE 'No' END AS acknowledged\nFROM analytics_dev.gold_engagement_progression\nWHERE highlight_count > 0\nORDER BY highlight_count DESC\nLIMIT 20"
    }
  ]
}
