                "query": {
                  "datasetName": "engagement_kpis",
                  "fields": [
                    { "name": "total_highlights", "expression": "`total_highlights`" }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
