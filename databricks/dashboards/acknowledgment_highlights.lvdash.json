              "frame": { "showTitle": true, "title": "Videos by Engagement Tier" }
            }
          },
          "position": { "x": 0, "y": 3, "width": 3, "height": 6 }
        },
        {
          "widget": {
            "name": "bar_highlights_by_channel",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "highlights_by_channel",
                  "fields": [
                    { "name": "channel_id", "expression": "`channel_id`" },
                    { "name": "total_highlights", "expression": "`total_highlights`" }
