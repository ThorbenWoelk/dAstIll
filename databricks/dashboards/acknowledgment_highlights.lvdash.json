                "x": {
                  "fieldName": "event_date",
                  "scale": { "type": "temporal" },
                  "displayName": "Date"
                },
                "y": {
                  "fieldName": "acknowledgment_count",
                  "scale": { "type": "quantitative" },
                  "displayName": "Acknowledgments"
                }
