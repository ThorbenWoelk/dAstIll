# dAstIll Configuration
# Copy this file to .env and update the values

# Path where transcripts will be stored (required)
# This is the single source of truth for transcript storage location
# IMPORTANT: Must be an absolute path (starting with /) or home directory path (starting with ~)
# Relative paths will be rejected with validation error and fallback to config file value
DASTILL_BASE_PATH="/Users/thorben.woelk/Documents/totos-vault/AI Memory/youtube library"
# Alternative home directory example:
# DASTILL_BASE_PATH="~/Documents/dAstIll/transcripts"

# Optional: Override config directory location (defaults to ./config)
# DASTILL_CONFIG_DIR=/path/to/config

# Optional: Enable debug logging
# DASTILL_DEBUG=false