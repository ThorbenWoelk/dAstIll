project_id              = "your-gcp-project-id"
region                  = "europe-west3"
app_name                = "dastill"
aws_region              = "eu-central-1"
youtube_api_key         = "your-youtube-api-key"
logfire_token           = "your-logfire-token"
backend_proxy_token     = "replace-with-a-long-random-proxy-token"
firebase_web_api_key    = "your-firebase-web-api-key"
# Optional; default is "{project_id}.firebaseapp.com"
# firebase_auth_domain  = "your-project.firebaseapp.com"
# Optional: set to let Terraform store the PAT; omit or "" if the secret already exists in GCP.
# databricks_token     = "your-databricks-personal-access-token"
ollama_url              = "https://your-ollama-proxy.com"
ollama_model            = "glm-5:cloud"
summary_evaluator_model = "glm-5:cloud"
ollama_fallback_model   = "qwen3-coder:30b"
ollama_embedding_model  = "embeddinggemma:latest"
